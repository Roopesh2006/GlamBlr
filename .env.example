# Supabase (already configured)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# EmailJS - Add your credentials to send booking confirmation emails
# Get these from https://www.emailjs.com/
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Tally Form for partner applications
NEXT_PUBLIC_TALLY_FORM_ID=your_tally_form_id

# Google Maps API Key (optional - for embedded maps)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# WhatsApp number for partner inquiries (with country code, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=916380691764
